---
---

<!-- DARK Section - Luxury Industrial Contact -->
<section class="section-cta py-24 md:py-32 lg:py-40 bg-black-pure overflow-hidden" id="cta">
  <div class="container max-w-7xl mx-auto px-8 md:px-12">

    <!-- Section Heading - THIN + LARGE -->
    <div class="text-center mb-16 md:mb-20">
      <h2 class="text-white font-light leading-tight mb-4 md:mb-6 tracking-[0.04em]
                 text-5xl md:text-6xl lg:text-7xl">
        LET'S BUILD<br />SOMETHING GREAT
      </h2>
      <div class="w-32 h-0.5 bg-bronze mx-auto mb-10 md:mb-12"></div>
      <p class="text-[#8B9AAB] text-base md:text-lg max-w-2xl mx-auto font-light leading-relaxed">
        Expert concrete and landscape construction serving Bakersfield and surrounding areas
      </p>
    </div>

    <!-- Contact Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">

      <!-- Left Side: Contact Info -->
      <div class="space-y-8">
        <div class="group">
          <div class="flex items-start gap-4 p-6 bg-charcoal border-l-2 border-transparent hover:border-bronze transition-all duration-300">
            <div class="text-bronze mt-1">
              <ion-icon class="text-3xl" name="call-outline"></ion-icon>
            </div>
            <div>
              <h3 class="text-white text-xl font-semibold mb-2 tracking-wide">PHONE</h3>
              <a
                href="tel:661-378-4017"
                class="text-[#8B9AAB] text-lg hover:text-bronze transition-colors duration-300"
              >
                661-378-4017
              </a>
            </div>
          </div>
        </div>

        <div class="group">
          <div class="flex items-start gap-4 p-6 bg-charcoal border-l-2 border-transparent hover:border-bronze transition-all duration-300">
            <div class="text-bronze mt-1">
              <ion-icon class="text-3xl" name="mail-outline"></ion-icon>
            </div>
            <div>
              <h3 class="text-white text-xl font-semibold mb-2 tracking-wide">EMAIL</h3>
              <a
                href="mailto:rockyconcreteinc22@gmail.com"
                class="text-[#8B9AAB] text-lg hover:text-bronze transition-colors duration-300 break-all"
              >
                rockyconcreteinc22@gmail.com
              </a>
            </div>
          </div>
        </div>

        <div class="group">
          <div class="flex items-start gap-4 p-6 bg-charcoal border-l-2 border-transparent hover:border-bronze transition-all duration-300">
            <div class="text-bronze mt-1">
              <ion-icon class="text-3xl" name="location-outline"></ion-icon>
            </div>
            <div>
              <h3 class="text-white text-xl font-semibold mb-2 tracking-wide">LOCATION</h3>
              <p class="text-[#8B9AAB] text-lg">
                Bakersfield, CA
              </p>
            </div>
          </div>
        </div>

        <!-- Social Links -->
        <div class="pt-8">
          <h3 class="text-white text-xl font-semibold mb-6 tracking-wide">FOLLOW US</h3>
          <div class="flex gap-4">
            <a
              href="https://www.tiktok.com/@rockyconcreteinc"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Visit our TikTok"
              class="w-12 h-12 flex items-center justify-center bg-charcoal text-[#8B9AAB] hover:text-white hover:bg-bronze transition-all duration-300"
            >
              <ion-icon class="text-2xl" name="logo-tiktok"></ion-icon>
            </a>
            <a
              href="https://www.instagram.com/rockyconcreteinc/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Visit our Instagram"
              class="w-12 h-12 flex items-center justify-center bg-charcoal text-[#8B9AAB] hover:text-white hover:bg-bronze transition-all duration-300"
            >
              <ion-icon class="text-2xl" name="logo-instagram"></ion-icon>
            </a>
            <a
              href="https://m.facebook.com/RockyConcreteInc/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Visit our Facebook"
              class="w-12 h-12 flex items-center justify-center bg-charcoal text-[#8B9AAB] hover:text-white hover:bg-bronze transition-all duration-300"
            >
              <ion-icon class="text-2xl" name="logo-facebook"></ion-icon>
            </a>
          </div>
        </div>
      </div>

      <!-- Right Side: Contact Form -->
      <div class="bg-charcoal p-8 md:p-12 border-2 border-[#2D2D2D]">
        <h3 class="text-white text-2xl md:text-3xl font-semibold mb-8 tracking-wide">
          REQUEST A FREE QUOTE
        </h3>

        <form
          class="space-y-6"
          action="https://formspree.io/f/xeojjaol"
          method="POST"
        >
          <div>
            <label
              for="full-name"
              class="block text-white font-medium mb-2 tracking-wide"
            >
              FULL NAME
            </label>
            <input
              id="full-name"
              type="text"
              name="full-name"
              required
              class="w-full px-4 py-3 bg-[#1A1A1A] border border-[#2D2D2D] text-white placeholder-[#64748B] focus:outline-none focus:border-bronze transition-all duration-300"
              placeholder="John Smith"
            />
          </div>

          <div>
            <label
              for="email"
              class="block text-white font-medium mb-2 tracking-wide"
            >
              EMAIL
            </label>
            <input
              id="email"
              type="email"
              name="email"
              required
              class="w-full px-4 py-3 bg-[#1A1A1A] border border-[#2D2D2D] text-white placeholder-[#64748B] focus:outline-none focus:border-bronze transition-all duration-300"
              placeholder="john@example.com"
            />
          </div>

          <div>
            <label
              for="phone"
              class="block text-white font-medium mb-2 tracking-wide"
            >
              PHONE (OPTIONAL)
            </label>
            <input
              id="phone"
              type="tel"
              name="phone"
              class="w-full px-4 py-3 bg-[#1A1A1A] border border-[#2D2D2D] text-white placeholder-[#64748B] focus:outline-none focus:border-bronze transition-all duration-300"
              placeholder="(555) 123-4567"
            />
          </div>

          <div>
            <label
              for="message"
              class="block text-white font-medium mb-2 tracking-wide"
            >
              PROJECT DETAILS
            </label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-3 bg-[#1A1A1A] border border-[#2D2D2D] text-white placeholder-[#64748B] resize-none focus:outline-none focus:border-bronze transition-all duration-300"
              placeholder="Tell us about your project..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-bronze text-white font-semibold py-4 px-8 hover:bg-[#A0750A] transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-bronze/50 tracking-wide"
          >
            SEND MESSAGE
          </button>
        </form>
      </div>

    </div>
  </div>
</section>
